APP_ENV=local_lan
APP_HOST=0.0.0.0
BACKEND_PORT=8010
FRONTEND_PORT=5173
LAN_ONLY=true
ALLOW_NO_AUTH=true
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-flash
DEEPSEEK_TEMPERATURE=0.1
DEEPSEEK_TIMEOUT_SECONDS=60
LOG_API_ERROR_DETAILS=false

ENABLE_VISION_TESTS=false
VISION_PROVIDER=groq_llama4_scout
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_VISION_TEMPERATURE=0.1
GROQ_VISION_TIMEOUT_SECONDS=60

MAX_ITERATIONS=30
CONTEXT_TOKEN_LIMIT=24000
CONTEXT_WARNING_RATIO=0.70
CONTEXT_COMPACT_RATIO=0.88
CONTEXT_RECENT_MESSAGES=8
CONTEXT_SUMMARY_MAX_CHARS=5000
WORKSPACE_PATH="/media/server/HD Backup/Servidores_NAO_MEXA/Banco_de_dados/Vortax/projetos"
RUNTIME_PATH="/media/server/HD Backup/Servidores_NAO_MEXA/Banco_de_dados/Vortax/runtime"
SCREENSHOT_INTERVAL=5
STREAM_SCREENSHOT_INTERVAL=2
VERTEX_STATIC_READY_SECONDS=4
PROJECT_VALIDATION_TIMEOUT_SECONDS=60

CHROME_BINARY=/usr/bin/google-chrome
CHROME_DEBUG_PORT=9222
CHROME_PROFILE_PATH=/dev/shm/vortax-chrome-profile

ENABLE_DESKTOP_AUTOMATION=true
REQUIRE_CONFIRMATION_FOR_DESKTOP=true

DATABASE_BASE_PATH="/media/server/HD Backup/Servidores_NAO_MEXA/Banco_de_dados"
DATABASE_EXTENSION=.sqlite
